# libro — secrets template
# ─────────────────────────────────────────────────────────────────────────────
# Ovo je TEMPLATE. Kopiraj ga u `.env` i popuni svoje keys.
# `.env` je u .gitignore i NIKAD ne ide u git/cloud.
#
#   cp .env.example .env
#   # zatim editaj .env i unesi prave vrijednosti
#
# Nakon toga libro-server.mjs će automatski čitati iz .env.
# Kad mijenjaš key — edit .env i restart server (`npm start`).
#
# Većinu setup-a NE radiš ovdje — koristi setup wizard koji se otvara
# automatski na prvom pokretanju (http://localhost:8765/setup.html).
# Ovaj fajl je SAMO za secrets (API keys, OAuth tokens).


# ─── AI (Anthropic Claude) ──────────────────────────────────────────────────
# Potrebno samo ako si u setup wizardu uključio AI.
# Dobivaš key na: https://console.anthropic.com/settings/keys
# Cost: pay-per-use, ~5-15 EUR/mj za prosječno korištenje.
# VAŽNO: nikad ne dijeli ovaj key (ne u chat, ne u commit, ne u screenshot).
ANTHROPIC_API_KEY=

# Model + dnevni limit (override-a vrijednosti iz libro-config.json).
# Opcije: claude-sonnet-4-5 (preporuka), claude-haiku-4-5 (jeftin), claude-opus-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_DAILY_LIMIT_USD=2


# ─── Gmail OAuth (opcionalno) ───────────────────────────────────────────────
# Potrebno samo ako želiš "Sync iz Gmaila" funkcionalnost (auto-skidanje izvoda
# i računa direktno iz inboxa). Setup wizard za OAuth:
#
#   node setup-gmail-auth.mjs
#
# Skripta će automatski popuniti sva 3 polja ispod.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Drugi (secondary) Gmail account — opcionalno. Knjigovodstvo emailovi se
# traže i tamo (npr. ako imaš odvojen privatni i poslovni account).
#   node setup-gmail-auth.mjs --secondary
GMAIL2_CLIENT_ID=
GMAIL2_CLIENT_SECRET=
GMAIL2_REFRESH_TOKEN=


# ─── Server config (opcionalno) ─────────────────────────────────────────────
# Default port je 8765. Promijeni ako konflikta s drugom aplikacijom.
# PORT=8765
